# ============================================================
# INPTIC DevOps - Configuration Environnement (EXEMPLE)
# ============================================================
# Copiez ce fichier vers .env et modifiez les valeurs
# Commande: cp .env.example .env
# ============================================================

# ── PostgreSQL Database ─────────────────────────────────────
POSTGRES_USER=inptic_user
POSTGRES_PASSWORD=changeme_postgres_password_2024
POSTGRES_DB=inptic_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Application Flask ───────────────────────────────────────
SECRET_KEY=changeme_secret_key_very_long_and_random_string_here
FLASK_ENV=production
FLASK_DEBUG=0
APP_PORT=5000

# ── Email Configuration (SMTP) ──────────────────────────────
# Pour Gmail: Utilisez un "App Password" (Mot de passe d'application)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=changeme_app_password_gmail
SMTP_USE_TLS=true

# Emails de notification
ADMIN_EMAIL=admin@example.com
NOTIFICATION_EMAIL=notifications@example.com

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_admin_password
GRAFANA_PORT=3000

# Configuration Grafana avancée
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_admin_password
GF_AUTH_ANONYMOUS_ENABLED=false
GF_USERS_ALLOW_SIGN_UP=false
GF_USERS_ALLOW_ORG_CREATE=false
GF_INSTALL_PLUGINS=

# ── Jenkins ─────────────────────────────────────────────────
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=changeme_jenkins_admin_password
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# Configuration Jenkins
JENKINS_OPTS=--prefix=/jenkins
JAVA_OPTS=-Djenkins.install.runSetupWizard=false -Xmx2g

# ── Prometheus ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_SCRAPE_INTERVAL=15s

# ── Alertmanager ────────────────────────────────────────────
ALERTMANAGER_PORT=9093

# Configuration des alertes email
ALERTMANAGER_SMTP_FROM=alertmanager@example.com
ALERTMANAGER_SMTP_TO=admin@example.com
ALERTMANAGER_SMTP_SMARTHOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_AUTH_USERNAME=votre.email@gmail.com
ALERTMANAGER_SMTP_AUTH_PASSWORD=changeme_app_password_gmail

# ── PostgreSQL Exporter ─────────────────────────────────────
POSTGRES_EXPORTER_PORT=9187
DATA_SOURCE_NAME=postgresql://inptic_user:changeme_postgres_password_2024@db:5432/inptic_db?sslmode=disable

# ── Monitoring & Métriques ──────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=5000

# ── Sécurité ────────────────────────────────────────────────
# Clé pour JWT (si utilisé)
JWT_SECRET_KEY=changeme_jwt_secret_key_very_long_random_string

# Session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ── Logs ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Backup ──────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7

# ── Réseau ──────────────────────────────────────────────────
NETWORK_NAME=monitoring

# ── Timezone ────────────────────────────────────────────────
TZ=Africa/Kinshasa

# ── GitHub/GitLab (pour Jenkins CI/CD) ─────────────────────
GIT_REPO_URL=https://github.com/Herlymba828/inptic-etudiants.git
GIT_BRANCH=main
GIT_USERNAME=
GIT_TOKEN=

# ── Docker Registry (optionnel) ─────────────────────────────
DOCKER_REGISTRY_URL=
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=

# ── Feature Flags ───────────────────────────────────────────
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false

# ── Limites & Performance ───────────────────────────────────
MAX_UPLOAD_SIZE=10485760
REQUEST_TIMEOUT=30
MAX_WORKERS=4
WORKER_CONNECTIONS=1000

# ── URLs Externes (pour webhooks, callbacks) ────────────────
EXTERNAL_URL=http://localhost:5000
JENKINS_URL=http://localhost:8080
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090

# ============================================================
# NOTES IMPORTANTES
# ============================================================
# 
# 1. SÉCURITÉ:
#    - Changez TOUS les mots de passe par défaut
#    - Utilisez des mots de passe forts (min 16 caractères)
#    - Ne commitez JAMAIS le fichier .env dans Git
#
# 2. GMAIL APP PASSWORD:
#    - Activez la validation en 2 étapes sur votre compte Google
#    - Générez un mot de passe d'application:
#      https://myaccount.google.com/apppasswords
#    - Utilisez ce mot de passe pour SMTP_PASSWORD
#
# 3. SECRET_KEY:
#    - Générez une clé aléatoire sécurisée:
#      python -c "import secrets; print(secrets.token_hex(32))"
#
# 4. PRODUCTION:
#    - Changez FLASK_ENV=production
#    - Changez FLASK_DEBUG=0
#    - Activez SESSION_COOKIE_SECURE=true (avec HTTPS)
#    - Configurez un vrai domaine dans EXTERNAL_URL
#
# 5. BACKUP:
#    - Configurez des sauvegardes régulières
#    - Testez la restauration périodiquement
#
# ============================================================
